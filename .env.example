# Supabase (eval/kalibrering - valgfritt, appen fungerer uten)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin API (Bearer token for /api/admin/eval/*)
ADMIN_API_KEY=your-admin-key

# Prediction model (valgfritt - appen bruker v1 baseline uten disse)
PREDICTION_MODEL=v2
PREDICTION_RESIDUAL_POLICY=time_window

# Vercel cron (valgfritt - kun for automatisk eval via Vercel cron)
CRON_SECRET=your-cron-secret

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=mosstrafikk.no
